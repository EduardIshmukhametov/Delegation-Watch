{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "sourceRoot": "src",
  "projects": {
    "api": {
      "type": "application",
      "root": "src/api",
      "entryFile": "main",
      "sourceRoot": "src/api",
      "compilerOptions": {
        "deleteOutDir": true,
        "tsConfigPath": "tsconfig.build.json"
      }
    },
    "indexer": {
      "type": "application",
      "root": "src/indexer",
      "entryFile": "main",
      "sourceRoot": "src/indexer",
      "compilerOptions": {
        "deleteOutDir": true,
        "tsConfigPath": "tsconfig.build.json"
      }
    }
  },
  "compilerOptions": {
    "deleteOutDir": true
  }
}
